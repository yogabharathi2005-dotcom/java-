import java.util.*;

public class Main {
    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);

        // Read the size of the array
        int n = sc.nextInt();

        // Create the array
        int arr[] = new int[n];

        // Variable to store the sum
        int sum = 0;

        // Read the array elements
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
            sum = sum + arr[i];
        }

        // Calculate average
        double average = (double) sum / n;

        // Print average
        System.out.println(average);
    }
}
