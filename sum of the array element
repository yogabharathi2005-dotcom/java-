import java.util.*;

public class Main {
    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int arr[] = new int[n];

        // Read the array
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }

        // Find the sum
        int sum = 0;
        for (int i = 0; i < n; i++) {
            sum = sum + arr[i];
        }

        System.out.println(sum);
    }
}
